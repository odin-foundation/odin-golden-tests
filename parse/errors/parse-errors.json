{
  "$schema": "https://odin.foundation/schemas/test-suite-v1.json",
  "suite": "parse-errors",
  "description": "Parse error conditions",
  "tests": [
    {
      "id": "error-duplicate-path",
      "description": "Duplicate path assignment",
      "input": "name = \"John\"\nname = \"Jane\"",
      "expectError": {
        "code": "P007",
        "message": "Duplicate path assignment"
      }
    },
    {
      "id": "error-unterminated-string",
      "description": "Unterminated quoted string",
      "input": "name = \"John",
      "expectError": {
        "code": "P004",
        "message": "Unterminated string"
      }
    },
    {
      "id": "error-non-contiguous-array",
      "description": "Non-contiguous array indices",
      "input": "items[0].name = \"First\"\nitems[5].name = \"Fifth\"",
      "expectError": {
        "code": "P013",
        "message": "Non-contiguous array indices"
      }
    },
    {
      "id": "error-invalid-array-index",
      "description": "Negative array index",
      "input": "items[-1].name = \"Invalid\"",
      "expectError": {
        "code": "P003",
        "message": "Invalid array index"
      }
    },
    {
      "id": "error-invalid-header",
      "description": "Invalid header syntax - unclosed array index",
      "input": "{invalid[}",
      "expectError": {
        "code": "P003",
        "message": "Invalid array index"
      }
    },
    {
      "id": "error-bare-string",
      "description": "Bare strings are not allowed",
      "input": "name = bare value",
      "expectError": {
        "code": "P002",
        "message": "Strings must be quoted"
      }
    },
    {
      "id": "error-unexpected-character",
      "description": "Unexpected character in value position",
      "input": "name = @#$invalid",
      "expectError": {
        "code": "P001"
      }
    },
    {
      "id": "error-invalid-escape",
      "description": "Invalid escape sequence in string",
      "input": "name = \"hello\\z world\"",
      "expectError": {
        "code": "P005"
      }
    },
    {
      "id": "error-invalid-type-prefix",
      "description": "Invalid type prefix - triple hash is not valid",
      "input": "value = ###42",
      "expectError": {
        "code": "P006"
      }
    },
    {
      "id": "error-invalid-header-unclosed",
      "description": "Invalid header syntax - missing closing brace",
      "input": "{Section\nname = \"test\"",
      "expectError": {
        "code": "P008"
      }
    },
    {
      "id": "valid-root-reset",
      "description": "Empty braces {} is a valid root section reset",
      "input": "{}\nname = \"test\"",
      "expected": {
        "assignments": {
          "name": { "type": "string", "value": "test" }
        }
      }
    },
    {
      "id": "error-max-depth",
      "description": "Maximum nesting depth exceeded with 201 levels of nesting",
      "input": "a.b.c.d.e.f.g.h.i.j.k.l.m.n.o.p.q.r.s.t.u.v.w.x.y.z.a1.b1.c1.d1.e1.f1.g1.h1.i1.j1.k1.l1.m1.n1.o1.p1.q1.r1.s1.t1.u1.v1.w1.x1.y1.z1.a2.b2.c2.d2.e2.f2.g2.h2.i2.j2.k2.l2.m2.n2.o2.p2.q2.r2.s2.t2.u2.v2.w2.x2.y2.z2.a3.b3.c3.d3.e3.f3.g3.h3.i3.j3.k3.l3.m3.n3.o3.p3.q3.r3.s3.t3.u3.v3.w3.x3.y3.z3.a4.b4.c4.d4.e4.f4.g4.h4.i4.j4.k4.l4.m4.n4.o4.p4.q4.r4.s4.t4.u4.v4.w4.x4.y4.z4.a5.b5.c5.d5.e5.f5.g5.h5.i5.j5.k5.l5.m5.n5.o5.p5.q5.r5.s5.t5.u5.v5.w5.x5.y5.z5.a6.b6.c6.d6.e6.f6.g6.h6.i6.j6.k6.l6.m6.n6.o6.p6.q6.r6.s6.t6.u6.v6.w6.x6.y6.z6.a7.b7.c7.d7.e7.f7.g7.h7.i7.j7.k7.l7.m7.n7.o7.p7.q7.r7.s7.t7.u7.v7.w7.x7.y7.z7.a8.b8.c8.d8.e8 = \"too deep\"",
      "expectError": {
        "code": "P010"
      }
    },
    {
      "id": "valid-empty-document",
      "description": "Empty document is valid — returns empty assignments",
      "input": "",
      "expected": {
        "assignments": {}
      }
    },
    {
      "id": "valid-whitespace-only-document",
      "description": "Document with only whitespace and comments is valid",
      "input": "  \n\n; just a comment\n  ",
      "expected": {
        "assignments": {}
      }
    },
    {
      "id": "error-array-index-out-of-range",
      "description": "Array index exceeds maximum allowed value",
      "input": "items[999999999].name = \"too big\"",
      "expectError": {
        "code": "P015"
      }
    },
    {
      "_comment": "P011 (Maximum document size exceeded) is not tested here because embedding a sufficiently large document in JSON is impractical. P012 (Invalid UTF-8 sequence) is not tested here because JSON cannot represent invalid UTF-8 byte sequences. Both should be tested at the SDK level with programmatic inputs.",
      "id": "error-unexpected-character-at-line-start",
      "description": "Unexpected character at the start of a line",
      "input": "@ = \"test\"",
      "expectError": {
        "code": "P001"
      }
    }
  ]
}
